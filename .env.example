# ════════════════════════════════════════════════════
#  DIGBA — Variables d'environnement
#  Copier ce fichier en .env et renseigner les valeurs
# ════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
APP_ENV=development           # development | production
APP_VERSION=1.0.0
DEBUG=true

# ── API Backend ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Base de données ───────────────────────────────────
DATABASE_URL=sqlite:///./backend/data/rasff/digba.db

# ── Pipeline Satellite (Sentinel-2 / AWS S3) ─────────
SENTINEL_BASE_URL=https://sentinel-s2-l2a.s3.amazonaws.com
SENTINEL_TILE=28PBV            # Tuile par défaut : Kaolack/Dakar
SENTINEL_SCALE=4               # 1=full res | 2=medium | 4=fast (recommandé)
SENTINEL_MAX_CLOUD_COVER=20    # % nuages maximum accepté

# ── Pipeline Météo (wttr.in) ─────────────────────────
WEATHER_API_URL=https://wttr.in
WEATHER_DEFAULT_CITY=Kaolack
WEATHER_TIMEOUT=10             # secondes

# ── Scoring — Pondérations (doivent sommer à 1.0) ────
WEIGHT_NDVI=0.35
WEIGHT_WEATHER=0.25
WEIGHT_RASFF=0.25
WEIGHT_OPERATOR=0.15

# ── Scoring — Seuils de décision ─────────────────────
SCORE_LOW_MAX=35               # Score < 35% → Faible risque
SCORE_MEDIUM_MAX=65            # Score < 65% → Risque modéré
                               # Score >= 65% → Risque élevé

# ── Seuils métier ────────────────────────────────────
AFB1_LIMIT_PPB=5               # Limite EU aflatoxine B1 (ppb)
NDVI_STRESS_THRESHOLD=0.2      # En dessous = stress végétatif
HUMIDITY_HIGH_THRESHOLD=80     # % humidité → risque mycotoxines
TEMP_HIGH_THRESHOLD=35         # °C → risque stockage

# ── CORS (Frontend) ──────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
